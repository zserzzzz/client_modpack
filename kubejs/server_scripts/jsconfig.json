{
    "compilerOptions": {
        "plugins": [],
        "checkJs": false,
        // Fully TS-compatible typing generation is not possible,
        // but turning off skipLibCheck can help debugging
        "skipLibCheck": true,
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "commonjs",
        "paths": {
            "@package": [
                "../../.probe/@package"
            ],
            "@package/*": [
                "../../.probe/@package/*"
            ],
            "@side-only/server": [
                "../../.probe/@side-only/server"
            ],
            "@side-only/server/*": [
                "../../.probe/@side-only/server/*"
            ],
            "@special": [
                "../../.probe/@special"
            ],
            "@special/*": [
                "../../.probe/@special/*"
            ]
        },
    },
    "typeAcquisition": {
        "enable": false
    },
    "include": [
        "./**/*.js",
        "./**/*.d.ts",
        "../../.probe/@package/**/*.d.ts",
        "../../.probe/@side-only/server/**/*.d.ts",
        "../../.probe/@special/**/*.d.ts"
    ]
}
